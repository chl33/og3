{
    "name": "og3",
    "version": "0.4.7",
    "description": "A library for esp projects",
    "keywords": "esp32, esp8266, modules, tasks, mqtt",
    "authors": [
        {
            "name": "Chris Lee",
            "email": "lee.chris.h@gmail.com",
            "url": "https://selectiveappeal.org/",
            "maintainer": true
        }
    ],
    "dependencies": [
        {
            "name": "bakercp/CRC32",
            "version": "~2.0.0"
        },
        {
            "name": "bblanchon/ArduinoJson",
            "version": "~7.0.0"
        },
        {
            "name": "hoeken/PsychicHttp",
            "version": "^1.2.1",
            "platforms": "espressif32"
        },
        {
            "name": "elims/PsychicMqttClient",
            "version": "^0.2.4",
            "platforms": "espressif32"
        },
        {
            "name": "ESP32Async/ESPAsyncWebServer",
            "version": "^3.6.0",
            "platforms": "espressif8266"
        },
        {
            "name": "marvinroger/AsyncMqttClient",
            "version": "^0.9.0",
            "platforms": "espressif8266"
        },
        {
            "name": "ESPAsyncTCP",
            "version": "^1.2.2",
            "platforms": "espressif8266"
        }
    ],
    "export": {
        "exclude": [
            ".*",
            "*~",
            "util/"
        ]
    },
    "license": "MIT",
    "frameworks": "*",
    "platforms": "espressif8266, espressif32, native",
    "repository": {
        "type": "git",
        "url": "https://github.com/chl33/og3"
    },
    "build": {
        "libLDFMode": "deep+",
        "libCompatMode": "strict"
    }
